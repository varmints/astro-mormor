<style is:global>
  :root {
    --gray-lighter: #f7f7f7;
    --gray-light: #dbdbdd;
    --gray-dark: #aeafb3;
    --gray-darker: #454547;
    --pink: #e89d93;
    --yellow: #eec71a;
  }

  * {
    box-sizing: border-box;
  }
  body {
    display: flex;
    align-items: center;
    justify-content: center;
    background: powderblue;
    color: var(--gray-darker);
  }
  .wrap {
    background: var(--gray-lighter);
    margin-top: 50px;
    margin-bottom: 50px;
    overflow: hidden;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .block {
    width: 25vw;
    height: 25vw;
  }
  .block-title {
    background: var(--gray-lighter);
    grid-column-start: 2;
    grid-column-end: -1;
    grid-row-start: 3;
    grid-row-end: 5;
    display: flex;
    transition: padding 0.3s linear;
    align-items: stretch;
    justify-content: space-between;
    flex-direction: column;
  }
  .block-title > div {
    display: flex;
    justify-content: space-between;
  }
  .block-title:hover {
    padding: 3em;
  }
  .block-title:hover .title-1 {
    order: 0;
  }
  .block-title:hover .title-2 {
    order: 2;
  }
  .block-title:hover .title-3 {
    order: 1;
  }
  .title-1,
  .title-3 {
    font-weight: 800;
  }
  .title-2 {
    font-weight: 600;
  }
  .title-3 {
    order: 1;
  }
  .style-1 {
    background: var(--gray-darker);
  }
  .style-2 {
    width: 0;
    height: 0;
    border: 12.5vw solid var(--gray-lighter);
    border-top-color: var(--gray-dark);
    border-bottom-color: var(--gray-dark);
    background: var(--gray-dark);
  }
  .style-3 {
    background-image: linear-gradient(
      135deg,
      var(--pink) 50%,
      var(--gray-light) 50%
    );
  }
  .style-4 {
    background-image: linear-gradient(
      var(--gray-lighter),
      var(--gray-lighter) 60%,
      var(--gray-darker) 60%,
      var(--gray-darker)
    );
    background-size: 100% 5%;
  }
  .style-5 {
    background-image: linear-gradient(
      45deg,
      var(--yellow) 50%,
      var(--gray-lighter) 50%
    );
  }
  .style-6 {
    background-image: linear-gradient(
        135deg,
        var(--gray-darker) 50%,
        transparent 50%
      ),
      linear-gradient(
        var(--gray-lighter),
        var(--gray-lighter) 60%,
        var(--gray-darker) 60%,
        var(--gray-darker)
      );
    background-size: 100%, 100% 5%;
  }
  .style-7 {
    background: linear-gradient(45deg, var(--gray-light) 50%, transparent 50%),
      radial-gradient(var(--gray-darker) 4px, transparent 4px),
      radial-gradient(var(--gray-darker) 4px, transparent 4px), transparent;
    background-size: 100%, 24px 24px, 24px 24px, 100%;
    background-position: 0 0, -2px 6px, 10px 18px, 0 0;
  }
  .style-8 {
    background-image: linear-gradient(
      315deg,
      var(--yellow) 50%,
      var(--gray-lighter) 50%
    );
  }
  .style-9 {
    background-image: linear-gradient(
      225deg,
      var(--pink) 50%,
      var(--gray-lighter) 50%
    );
  }
  .style-10 {
    background: var(--gray-light);
  }
  .style-11 {
    background-image: linear-gradient(
      45deg,
      var(--pink) 50%,
      var(--gray-lighter) 50%
    );
  }
  .style-12 {
    background-image: linear-gradient(
      225deg,
      var(--yellow) 50%,
      var(--gray-lighter) 50%
    );
  }
  .block-13 {
    background-image: linear-gradient(
      to right,
      var(--pink),
      var(--pink) 44%,
      var(--gray-lighter) 44%,
      var(--gray-lighter)
    );
    background-size: 5% 100%;
  }
</style>

<!-- 
This pen uses flex and grid for alignment and layout (respectively), and background gradients for the different tiles (with a couple of exceptions: style-1, style-2 and style-10).
-->
<div class="wrap rounded-3xl">
  <div class="block-title p-24">
    <!-- feels a little hacky wrapping every character, but makes alignment super easy without the need for JS or hacks -->
    <div class="title-1 text-6xl">
      <span>M</span>
      <span>O</span>
      <span>R</span>
      <span>M</span>
      <span>O</span>
      <span>R</span>
    </div>
    <div class="title-3 text-6xl">
      <span>D</span>
      <span>E</span>
      <span>V</span>
      <span>E</span>
      <span>L</span>
      <span>O</span>
      <span>P</span>
      <span>E</span>
      <span>R</span>
    </div>
    <div class="title-2 text-3xl">
      <span>F</span>
      <span>R</span>
      <span>O</span>
      <span>N</span>
      <span>T</span>
      <span>E</span>
      <span>N</span>
      <span>D</span>
      <span>&nbsp;</span>
      <span>W</span>
      <span>E</span>
      <span>B</span>
    </div>
  </div>
  <div class="block style-1"></div>
  <div class="block style-2"></div>
  <div class="block style-3"></div>
  <div class="block style-4"></div>
  <div class="block style-5"></div>
  <div class="block style-6"></div>
  <div class="block style-7"></div>
  <div class="block style-8"></div>
  <div class="block style-9"></div>
  <div class="block style-10"></div>
  <div class="block style-6"></div>
  <div class="block style-3"></div>
  <div class="block style-12"></div>
  <div class="block style-1"></div>
  <div class="block style-11"></div>
  <div class="block style-7"></div>
  <div class="block style-2"></div>
  <div class="block-13"></div>
</div>
